rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.plannerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.plannerId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
        (resource.data.creativeId == request.auth.uid ||
         resource.data.plannerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.plannerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.creativeId == request.auth.uid ||
         resource.data.plannerId == request.auth.uid);
      allow delete: if isAuthenticated() &&
        (resource.data.creativeId == request.auth.uid ||
         resource.data.plannerId == request.auth.uid);
    }

    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated();
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
  }
}
